		{
			"name": "Ventas",
			"item": [
				{
					"name": "Registrar Venta",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"if (pm.response.code === 200 || pm.response.code === 201) {",
									"    var jsonData = pm.response.json();",
									"    pm.environment.set(\"venta_id\", jsonData.id);",
									"    pm.test(\"Venta registrada exitosamente\", function () {",
									"        pm.expect(jsonData.id).to.exist;",
									"        pm.expect(jsonData.total).to.exist;",
									"        pm.expect(jsonData.detalles).to.be.an('array');",
									"    });",
									"    console.log(\"✅ Venta ID guardado: \" + jsonData.id);",
									"    console.log(\"   Total: $\" + jsonData.total);",
									"    console.log(\"   Items: \" + jsonData.detalles.length);",
									"    console.log(\"   Usuario: \" + jsonData.usuarioNombre);",
									"}"
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									"var productoId = pm.environment.get(\"producto_id\");",
									"if (!productoId) {",
									"    console.error(\"⚠️ producto_id no está definido. Ejecuta 'Crear Producto' primero.\");",
									"}"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"items\": [\n    {\n      \"productoId\": {{producto_id}},\n      \"cantidad\": 2\n    }\n  ]\n}"
						},
						"url": {
							"raw": "{{base_url}}/api/ventas",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"ventas"
							]
						},
						"description": "Registrar una nueva venta con uno o más productos. El usuario se obtiene automáticamente del token JWT."
					},
					"response": []
				},
				{
					"name": "Listar Ventas",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Ventas listadas correctamente\", function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"    if (jsonData.length > 0) {",
									"        pm.expect(jsonData[0]).to.have.property('id');",
									"        pm.expect(jsonData[0]).to.have.property('total');",
									"        pm.expect(jsonData[0]).to.have.property('fecha');",
									"        pm.expect(jsonData[0]).to.have.property('detalles');",
									"    }",
									"    console.log(\"✅ Total de ventas: \" + jsonData.length);",
									"    ",
									"    var totalVentas = 0;",
									"    jsonData.forEach(function(venta) {",
									"        totalVentas += venta.total;",
									"    });",
									"    console.log(\"   Total vendido: $\" + totalVentas.toFixed(2));",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/ventas",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"ventas"
							]
						},
						"description": "Listar todas las ventas registradas"
					},
					"response": []
				}
