						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Producto encontrado\", function () {",
									"    pm.response.to.have.status(200);",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.id).to.eql(parseInt(pm.environment.get(\"producto_id\")));",
									"    console.log(\"✅ Producto: \" + jsonData.nombre);",
									"    console.log(\"   Stock actual: \" + jsonData.stock);",
									"    console.log(\"   Precio: $\" + jsonData.precio);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
