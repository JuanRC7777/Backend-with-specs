					},
					"response": []
				},
				{
					"name": "Listar Productos",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code es 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Respuesta es un array\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.be.an('array');",
									"});",
									"",
									"pm.test(\"Productos tienen estructura correcta\", function () {",
									"    var jsonData = pm.response.json();",
									"    if (jsonData.length > 0) {",
									"        pm.expect(jsonData[0]).to.have.property('id');",
									"        pm.expect(jsonData[0]).to.have.property('nombre');",
									"        pm.expect(jsonData[0]).to.have.property('precio');",
									"        pm.expect(jsonData[0]).to.have.property('stock');",
									"        pm.expect(jsonData[0]).to.have.property('activo');",
									"    }",
									"    console.log(\"✅ Total de productos: \" + jsonData.length);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "GET",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"url": {
							"raw": "{{base_url}}/api/productos",
							"host": [
								"{{base_url}}"
							],
							"path": [
								"api",
								"productos"
							]
						},
						"description": "Listar todos los productos activos"
					},
					"response": []
